{
  "name": "meta-agents-harness",
  "version": "0.2.0",
  "description": "Unified multi-agent harness that detects OpenCode, Claude, or PI runtime and adapts commands dynamically.",
  "type": "module",
  "bin": {
    "mah": "bin/mah"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "bootstrap:meta": "node scripts/bootstrap-meta-agents.mjs",
    "sync:meta": "node scripts/sync-meta-agents.mjs",
    "check:meta-sync": "node scripts/sync-meta-agents.mjs --check",
    "validate:config": "node scripts/validate-meta-config.mjs",
    "validate:sync": "node scripts/sync-meta-agents.mjs --check",
    "validate:all": "node scripts/meta-agents-harness.mjs validate:all",
    "detect": "node scripts/meta-agents-harness.mjs detect",
    "explain": "node scripts/meta-agents-harness.mjs explain",
    "init": "node scripts/meta-agents-harness.mjs init",
    "plan": "node scripts/meta-agents-harness.mjs plan",
    "diff": "node scripts/meta-agents-harness.mjs diff",
    "sessions": "node scripts/meta-agents-harness.mjs sessions",
    "graph": "node scripts/meta-agents-harness.mjs graph",
    "demo": "node scripts/meta-agents-harness.mjs demo",
    "contract:runtime": "node scripts/meta-agents-harness.mjs contract:runtime",
    "doctor": "node scripts/meta-agents-harness.mjs doctor",
    "check:runtime": "node scripts/meta-agents-harness.mjs check:runtime",
    "validate:runtime": "node scripts/meta-agents-harness.mjs validate:runtime",
    "validate": "node scripts/meta-agents-harness.mjs validate",
    "list:crews": "node scripts/meta-agents-harness.mjs list:crews",
    "use": "node scripts/meta-agents-harness.mjs use",
    "clear": "node scripts/meta-agents-harness.mjs clear",
    "run": "node scripts/meta-agents-harness.mjs run",
    "test:smoke": "node --test tests/smoke.test.mjs",
    "test:contract": "node --test tests/runtime-contract.test.mjs",
    "test:diagnostics": "node --test tests/diagnostics-json.test.mjs tests/sync-helpers.test.mjs tests/platform-reliability.test.mjs"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
