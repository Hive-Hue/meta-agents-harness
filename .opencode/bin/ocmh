#!/usr/bin/env node
import { spawnSync } from "node:child_process"
import { chmodSync } from "node:fs"
import path from "node:path"
import { fileURLToPath } from "node:url"

const __filename = fileURLToPath(import.meta.url)
const __dirname = path.dirname(__filename)
const runtimeRoot = path.resolve(__dirname, "..")
const repoRoot = path.resolve(runtimeRoot, "..")
const scriptsDir = path.join(runtimeRoot, "scripts")

const COMMANDS = {
  "list:crews": "list-crews.mjs",
  list: "list-crews.mjs",
  ls: "list-crews.mjs",
  "use:crew": "use-crew.mjs",
  use: "use-crew.mjs",
  "clear:crew": "clear-crew.mjs",
  clear: "clear-crew.mjs",
  "run:crew": "run-crew-opencode.mjs",
  run: "run-crew-opencode.mjs",
  "check:runtime": "check-runtime.mjs",
  doctor: "doctor.mjs",
  validate: "check-runtime.mjs"
}

function printHelp() {
  console.log("Usage: ocmh <command> [args]")
  console.log("")
  console.log("Core commands:")
  console.log("  ocmh list:crews")
  console.log("  ocmh use <crew> [--hierarchy|--no-hierarchy]")
  console.log("  ocmh clear")
  console.log("  ocmh check:runtime")
  console.log("  ocmh doctor")
  console.log("  ocmh run [--crew <crew>] [--hierarchy|--no-hierarchy] [-- <opencode-args>]")
}

function runScript(scriptFile, args) {
  const scriptPath = path.join(scriptsDir, scriptFile)
  const child = spawnSync(process.execPath, [scriptPath, ...args], {
    cwd: repoRoot,
    stdio: "inherit",
    env: process.env
  })
  process.exitCode = typeof child.status === "number" ? child.status : 1
}

function normalizeUseCrew(raw) {
  if (!raw) return ""
  const value = raw.trim()
  if (!value) return ""
  if (value.startsWith("--") && value.length > 2) return value.slice(2)
  return value
}

function main() {
  try {
    chmodSync(__filename, 0o755)
  } catch {}

  const argv = process.argv.slice(2)
  const first = argv[0]
  if (!first || first === "-h" || first === "--help" || first === "help") {
    printHelp()
    return
  }

  if (first === "--use" || first.startsWith("--use=")) {
    const crew = first.startsWith("--use=")
      ? normalizeUseCrew(first.slice("--use=".length))
      : normalizeUseCrew(argv[1])
    if (!crew) {
      console.error("ERROR: missing crew name for --use")
      process.exitCode = 1
      return
    }
    runScript("use-crew.mjs", [crew, ...argv.slice(2)])
    return
  }

  if (first === "use" || first === "use:crew") {
    const crew = normalizeUseCrew(argv[1])
    if (!crew) {
      console.error("ERROR: missing crew name for use")
      process.exitCode = 1
      return
    }
    runScript("use-crew.mjs", [crew, ...argv.slice(2)])
    return
  }

  if (first.startsWith("-")) {
    runScript("run-crew-opencode.mjs", argv)
    return
  }

  const script = COMMANDS[first]
  if (!script) {
    console.error(`ERROR: unknown command: ${first}`)
    process.exitCode = 1
    return
  }

  runScript(script, argv.slice(1))
}

main()
