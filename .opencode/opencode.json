{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    },
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "question": "allow",
    "update-mental-model": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "/usr/bin/github-mcp-server",
        "stdio"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}",
        "GITHUB_TOOLSETS": "repos,issues,pull_requests"
      },
      "enabled": true
    }
  }
}
