#!/usr/bin/env node
import { spawnSync } from "node:child_process"
import path from "node:path"
import { fileURLToPath } from "node:url"
import { ensureMahHomeLayout, resolveMahHome } from "../scripts/core/mah-home.mjs"

const __filename = fileURLToPath(import.meta.url)
const __dirname = path.dirname(__filename)
const packageRoot = path.resolve(__dirname, "..")
const mahHome = resolveMahHome()

try {
  ensureMahHomeLayout({ packageRoot })
} catch (error) {
  console.warn(`[mah] failed to initialize MAH home at ${mahHome}: ${error?.message || error}`)
}

const cliPath = path.resolve(__dirname, "..", "scripts", "meta-agents-harness.mjs")
const child = spawnSync(process.execPath, [cliPath, ...process.argv.slice(2)], {
  cwd: process.cwd(),
  env: {
    ...process.env,
    MAH_PACKAGE_ROOT: process.env.MAH_PACKAGE_ROOT || packageRoot,
    MAH_HOME: process.env.MAH_HOME || mahHome
  },
  stdio: "inherit"
})

if (typeof child.status === "number") {
  process.exitCode = child.status
} else if (child.error) {
  console.error(`ERROR: ${child.error.message}`)
  process.exitCode = 1
} else {
  process.exitCode = 1
}
